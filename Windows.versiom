## **🤖 Instructions for an AI Agent**
*(To automate the post-installation process)*

---
### **📌 AI Agent Requirements**
1. **Run as Administrator** (all commands require admin rights).
2. **Backup the system** before making changes.
3. **Check for critical services** (NVIDIA, Wacom, licensing) and **skip disabling them**.
4. **Log all actions** for debugging.

---

### **🔹 AI Agent Script (PowerShell)**
Save this as **`OpenWin11_Agent.ps1`** and run as **Administrator**.

```powershell
<#
.SYNOPSIS
    AI Agent Script to Transform Windows 11 into an Open, Non-Restricted System.
.DESCRIPTION
    This script:
    - Creates a restore point.
    - Debloats Windows 11 (removes bloatware, disables telemetry).
    - Disables forced updates.
    - Blocks tracking domains.
    - Preserves critical services (NVIDIA, Wacom, licensing).
    - Customizes UI (Open-Shell, RoundedTB, large text).
    - Installs package managers (Winget, Scoop).
.NOTES
    Run as Administrator.
    Tested for Windows 11 22H2/23H2.
    Requires: PowerShell 5.1+, Internet connection.
#>

# Require Admin
if (-NOT ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    Write-Warning "Please run this script as Administrator."
    exit
}

# Log file
$LogFile = "C:\OpenWin11\Agent_Log_$(Get-Date -Format 'yyyyMMdd_HHmmss').txt"
Start-Transcript -Path $LogFile -Append

# --- Step 1: Create Restore Point ---
Write-Host "`n[1/12] Creating a system restore point..."
try {
    Checkpoint-Computer -Description "Pre-OpenWin11-Agent-Tweaks" -RestorePointType MODIFY_SETTINGS
    Write-Host "✅ Restore point created."
} catch {
    Write-Warning "❌ Failed to create restore point: $_"
}

# --- Step 2: Download Required Tools ---
Write-Host "`n[2/12] Downloading required tools..."
$ToolsDir = "C:\OpenWin11"
if (-not (Test-Path $ToolsDir)) { New-Item -ItemType Directory -Path $ToolsDir -Force }

# Download Sycnex Debloater
$DebloaterUrl = "https://raw.githubusercontent.com/Sycnex/Windows10Debloater/master/Windows10Debloater.ps1"
$DebloaterPath = "$ToolsDir\Windows10Debloater.ps1"
Invoke-WebRequest -Uri $DebloaterUrl -OutFile $DebloaterPath

# Download DisableWinTracking
$TrackingUrl = "https://raw.githubusercontent.com/10se1ucgo/DisableWinTracking/master/DisableWinTracking.ps1"
$TrackingPath = "$ToolsDir\DisableWinTracking.ps1"
Invoke-WebRequest -Uri $TrackingUrl -OutFile $TrackingPath

# --- Step 3: Debloat Windows 11 ---
Write-Host "`n[3/12] Debloating Windows 11..."
try {
    & $DebloaterPath -Mode Full -AutoRemove -SkipWindowsUpdate
    Write-Host "✅ Debloating complete."
} catch {
    Write-Warning "❌ Debloating failed: $_"
}

# --- Step 4: Disable Telemetry ---
Write-Host "`n[4/12] Disabling telemetry..."
try {
    & $TrackingPath -DisableTelemetry -DisableCortana -DisableOneDrive
    Write-Host "✅ Telemetry disabled."
} catch {
    Write-Warning "❌ Telemetry disable failed: $_"
}

# Block telemetry domains via hosts file
$HostsPath = "$env:SystemRoot\System32\drivers\etc\hosts"
$TelemetryDomains = @(
    "telemetry.microsoft.com",
    "vortex.data.microsoft.com",
    "settings-sandbox.data.microsoft.com",
    "wns.notify.windows.com",
    "reports.wes.df.telemetry.microsoft.com",
    "services.wes.df.telemetry.microsoft.com",
    "sqm.telemetry.microsoft.com",
    "oca.telemetry.microsoft.com"
)
foreach ($Domain in $TelemetryDomains) {
    try {
        Add-Content -Path $HostsPath -Value "127.0.0.1 $Domain" -ErrorAction SilentlyContinue
        Write-Host "✅ Blocked: $Domain"
    } catch {
        Write-Warning "❌ Failed to block $Domain"
    }
}

# --- Step 5: Disable Forced Updates ---
Write-Host "`n[5/12] Disabling forced updates..."
try {
    # Group Policy method (if available)
    if (Test-Path "C:\Windows\System32\gpedit.msc") {
        reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\WindowsUpdate" /v SetUpdateNotificationLevel /t REG_DWORD /d 1 /f
        reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\WindowsUpdate" /v DoNotConnectToWindowsUpdateInternetLocations /t REG_DWORD /d 1 /f
        Write-Host "✅ Group Policy updates disabled."
    } else {
        # Registry method
        reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\WindowsUpdate" /v SetUpdateNotificationLevel /t REG_DWORD /d 1 /f
        reg add "HKLM\SOFTWARE\Policies\Microsoft\Windows\WindowsUpdate" /v DoNotConnectToWindowsUpdateInternetLocations /t REG_DWORD /d 1 /f
        Write-Host "✅ Registry updates disabled."
    }
} catch {
    Write-Warning "❌ Failed to disable updates: $_"
}

# --- Step 6: Disable Unnecessary Services ---
Write-Host "`n[6/12] Disabling unnecessary services..."
$SafeToDisable = @(
    "DiagTrack",
    "dmwappushservice",
    "WSearch",
    "SysMain",
    "WerSvc"
)
foreach ($Service in $SafeToDisable) {
    try {
        Stop-Service -Name $Service -Force -ErrorAction SilentlyContinue
        Set-Service -Name $Service -StartupType Disabled
        Write-Host "✅ Disabled: $Service"
    } catch {
        Write-Warning "❌ Failed to disable $Service"
    }
}

# --- Step 7: Preserve Critical Services ---
Write-Host "`n[7/12] Ensuring critical services are running..."
$CriticalServices = @(
    "NvContainerLocalSystem",
    "TabletInputService",
    "CryptSvc",
    "Winmgmt",
    "Audiosrv"
)
foreach ($Service in $CriticalServices) {
    try {
        if ((Get-Service -Name $Service -ErrorAction SilentlyContinue).Status -ne "Running") {
            Start-Service -Name $Service -ErrorAction SilentlyContinue
            Set-Service -Name $Service -StartupType Automatic
            Write-Host "✅ Ensured $Service is running."
        }
    } catch {
        Write-Warning "⚠️ $Service not found or already running."
    }
}

# --- Step 8: Disable Scheduled Tasks ---
Write-Host "`n[8/12] Disabling unnecessary scheduled tasks..."
$TasksToDisable = @(
    "Microsoft\Windows\Application Experience\Microsoft Compatibility Appraiser",
    "Microsoft\Windows\Application Experience\ProgramDataUpdater",
    "Microsoft\Windows\Autochk\Proxy",
    "Microsoft\Windows\Customer Experience Improvement Program\Consolidator",
    "Microsoft\Windows\DataIntegrityScan\DataIntegrity",
    "Microsoft\Windows\DiskDiagnostic\Microsoft-Windows-DiskDiagnosticDataCollector",
    "Microsoft\Windows\WindowsUpdate\Scheduled Start"
)
foreach ($Task in $TasksToDisable) {
    try {
        Disable-ScheduledTask -TaskName $Task -ErrorAction SilentlyContinue
        Write-Host "✅ Disabled task: $Task"
    } catch {
        Write-Warning "❌ Failed to disable $Task"
    }
}

# --- Step 9: Allow Unsigned Drivers (Test Mode) ---
Write-Host "`n[9/12] Enabling Test Mode for unsigned drivers..."
try {
    bcdedit /set testsigning on
    Write-Host "✅ Test Mode enabled. Reboot to apply."
} catch {
    Write-Warning "❌ Failed to enable Test Mode: $_"
}

# --- Step 10: Customize UI ---
Write-Host "`n[10/12] Customizing UI..."
try {
    # Enable large text
    Set-ItemProperty -Path "HKCU:\Control Panel\Desktop" -Name "LogPixels" -Value 192
    Set-ItemProperty -Path "HKCU:\Control Panel\Desktop" -Name "WheelScrollLines" -Value 3

    # Disable animations
    Set-ItemProperty -Path "HKCU:\Control Panel\Desktop\WindowMetrics" -Name "MinAnimate" -Value 0
    Write-Host "✅ UI customized (large text, no animations)."
} catch {
    Write-Warning "❌ UI customization failed: $_"
}

# --- Step 11: Install Package Managers ---
Write-Host "`n[11/12] Installing package managers..."
try {
    # Winget (built-in)
    Write-Host "✅ Winget is available (built-in)."

    # Scoop
    if (-not (Test-Path "$env:USERPROFILE\scoop")) {
        Set-ExecutionPolicy RemoteSigned -Scope CurrentUser
        Invoke-Expression (New-Object System.Net.WebClient).DownloadString('https://get.scoop.sh')
        Write-Host "✅ Scoop installed."
    }
} catch {
    Write-Warning "❌ Package manager installation failed: $_"
}

# --- Step 12: Final Verification ---
Write-Host "`n[12/12] Verification complete. Please test your workflow:"
Write-Host "- DaVinci Resolve (CUDA acceleration)"
Write-Host "- Affinity Suite (Hardware acceleration)"
Write-Host "- Wacom Tablet (Pen pressure/tilt)"
Write-Host "- DXO/Luminar Neo (Licensing)"
Write-Host "- NVIDIA Drivers (Control Panel)"
Write-Host "`n📌 Reboot your system to apply all changes."

Stop-Transcript
```

---
