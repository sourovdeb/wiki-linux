#!/usr/bin/env python3
"""Generate a live Wiki-Linux wallpaper image with current system/wiki status."""
import json
import os
import subprocess
from datetime import datetime
from pathlib import Path

WIKI_ROOT = Path(os.environ.get("WIKI_ROOT", str(Path.home() / "wiki"))).expanduser()
OUT_DIR = Path.home() / ".cache" / "wiki-wallpaper"
OUT_DIR.mkdir(parents=True, exist_ok=True)
OUT_FILE = OUT_DIR / "wiki-live.png"


def run(cmd, timeout=4):
    try:
        res = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout, check=False)
        return res.returncode, res.stdout.strip(), res.stderr.strip()
    except Exception:
        return 1, "", ""


def page_count():
    if not WIKI_ROOT.exists():
        return 0
    return sum(1 for p in WIKI_ROOT.rglob("*.md") if "_archive" not in p.parts)


def git_last_update():
    code, out, _ = run(["git", "-C", str(WIKI_ROOT), "log", "-1", "--format=%ar"])
    return out if code == 0 and out else "unknown"


def git_changes():
    code, out, _ = run(["git", "-C", str(WIKI_ROOT), "status", "--porcelain"])
    if code != 0:
        return "n/a"
    return str(len([line for line in out.splitlines() if line.strip()]))


def disk_free():
    code, out, _ = run(["df", "-h", str(WIKI_ROOT if WIKI_ROOT.exists() else Path.home())])
    if code != 0 or not out:
        return "?"
    lines = out.splitlines()
    if len(lines) < 2:
        return "?"
    fields = lines[-1].split()
    return fields[3] if len(fields) >= 4 else "?"


def service_status():
    code, out, _ = run(["systemctl", "--user", "is-active", "wiki-monitor"], timeout=3)
    if code == 0 and out == "active":
        return "active"
    return "inactive"


def ollama_models():
    code, out, _ = run(["curl", "-fsS", "--max-time", "2", "http://127.0.0.1:11434/api/tags"], timeout=3)
    if code != 0:
        return "down"
    try:
        data = json.loads(out)
        return str(len(data.get("models", [])))
    except Exception:
        return "?"


def webui_status():
    code, _, _ = run(["curl", "-fsS", "--max-time", "2", "http://127.0.0.1:8080"], timeout=3)
    return "up" if code == 0 else "down"


def imagick_cmd():
    for cmd in ("magick", "convert"):
        code, _, _ = run(["bash", "-lc", f"command -v {cmd}"])
        if code == 0:
            return cmd
    return ""


def main():
    im = imagick_cmd()
    if not im:
        raise SystemExit("ImageMagick command not found (magick/convert)")

    stats = {
        "pages": page_count(),
        "changes": git_changes(),
        "disk": disk_free(),
        "monitor": service_status(),
        "models": ollama_models(),
        "webui": webui_status(),
        "updated": git_last_update(),
        "now": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
    }

    text = "\\n".join([
        "WIKI-LINUX LIVE DESKTOP",
        "",
        f"Pages: {stats['pages']}      Pending Changes: {stats['changes']}",
        f"wiki-monitor: {stats['monitor']}      WebUI: {stats['webui']}",
        f"Ollama Models: {stats['models']}      Free Disk: {stats['disk']}",
        f"Last Update: {stats['updated']}",
        f"Now: {stats['now']}",
        "",
        "Shortcuts: Super+Space (search)  |  Super+F1 (guide)",
        "Action: wiki-status-panel  |  wiki-search-dialog",
    ])

    subprocess.run([im, "-size", "1920x1080", "gradient:#0e1c2f-#17324f", str(OUT_FILE)], check=False)
    subprocess.run([
        im,
        str(OUT_FILE),
        "-font", "DejaVu-Sans-Mono",
        "-pointsize", "30",
        "-fill", "#f5f7ff",
        "-gravity", "Center",
        "-annotate", "+0+0", text,
        str(OUT_FILE),
    ], check=False)
    subprocess.run([
        im,
        str(OUT_FILE),
        "-font", "DejaVu-Sans",
        "-pointsize", "22",
        "-fill", "#8ed0ff",
        "-gravity", "SouthEast",
        "-annotate", "+40+34", "Wiki-Linux objective: learn, track, recover",
        str(OUT_FILE),
    ], check=False)

    print(str(OUT_FILE))


if __name__ == "__main__":
    main()
