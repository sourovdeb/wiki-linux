#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"
wiki_root="${WIKI_ROOT:-$HOME/wiki}"
dashboard_note="$repo_root/user/notes/my-day.md"

if [[ ! -d "$wiki_root" ]]; then
  wiki_root="$repo_root"
fi

need_zenity() {
  if ! command -v zenity >/dev/null 2>&1; then
    printf 'zenity is required for the dashboard menu.\n' >&2
    exit 1
  fi
}

temp_text() {
  local title="$1"
  local file="$2"
  zenity --text-info \
    --title="$title" \
    --width=940 \
    --height=680 \
    --filename="$file"
}

open_dashboard() {
  if command -v obsidian >/dev/null 2>&1; then
    obsidian "$dashboard_note" >/dev/null 2>&1 &
  else
    xdg-open "$dashboard_note" >/dev/null 2>&1 &
  fi
}

open_webui() {
  if command -v ollama-view >/dev/null 2>&1; then
    ollama-view auto >/dev/null 2>&1 &
  else
    xdg-open "http://127.0.0.1:8080" >/dev/null 2>&1 &
  fi
}

open_chromium_ai() {
  if command -v ollama-view >/dev/null 2>&1; then
    ollama-view chromium >/dev/null 2>&1 &
  elif command -v chromium >/dev/null 2>&1; then
    chromium --new-window --enable-features=SidePanelPinning,ReadAnything "http://127.0.0.1:8080" >/dev/null 2>&1 &
  else
    zenity --info --title="Chromium AI" --text="Chromium is not installed." >/dev/null 2>&1 || true
  fi
}

open_firefox_ai() {
  if command -v ollama-view >/dev/null 2>&1; then
    ollama-view firefox >/dev/null 2>&1 &
  elif command -v firefox >/dev/null 2>&1; then
    firefox --new-window "http://127.0.0.1:8080" >/dev/null 2>&1 &
  else
    zenity --info --title="Firefox AI" --text="Firefox is not installed." >/dev/null 2>&1 || true
  fi
}

new_note() {
  local title slug note_path
  title="$(zenity --entry --title="New Note" --text="Title for the new note:")" || exit 0
  [[ -n "$title" ]] || exit 0
  slug="$(printf '%s' "$title" | tr '[:upper:] ' '[:lower:]-' | tr -cd 'a-z0-9-')"
  note_path="$repo_root/user/notes/$(date +%Y-%m-%d)-${slug}.md"
  if [[ -e "$note_path" ]]; then
    note_path="$repo_root/user/notes/$(date +%Y-%m-%d)-${slug}-$(date +%H%M%S).md"
  fi
  mkdir -p "$(dirname "$note_path")"
  cat > "$note_path" <<EOF
---
title: $title
updated: $(date +%Y-%m-%d)
tags: []
---

# $title

EOF
  if command -v obsidian >/dev/null 2>&1; then
    obsidian "$note_path" >/dev/null 2>&1 &
  else
    xdg-open "$note_path" >/dev/null 2>&1 &
  fi
}

search_wiki() {
  local query tmp
  query="$(zenity --entry --title="Search Wiki" --text="Search term:")" || exit 0
  [[ -n "$query" ]] || exit 0
  tmp="$(mktemp)"
  if command -v rg >/dev/null 2>&1; then
    rg -n --hidden --glob '*.md' -F -- "$query" "$wiki_root" > "$tmp" || true
  else
    grep -RIn --include='*.md' -F -- "$query" "$wiki_root" > "$tmp" 2>/dev/null || true
  fi
  if [[ ! -s "$tmp" ]]; then
    printf 'No matches found for: %s\n' "$query" > "$tmp"
  fi
  temp_text "Wiki Search Results" "$tmp"
  rm -f "$tmp"
}

ask_ollama() {
  local prompt tmp answer
  prompt="$(zenity --entry --title="Ask Ollama" --text="Question:")" || exit 0
  [[ -n "$prompt" ]] || exit 0
  tmp="$(mktemp)"
  if command -v ask-ollama >/dev/null 2>&1; then
    ask-ollama "$prompt" > "$tmp"
  else
    answer="$(curl -s http://localhost:11434/api/generate \
      -d "$(jq -n --arg p "$prompt" '{model:"mistral",prompt:$p,stream:false}')" \
      | jq -r '.response')"
    printf '%s\n' "$answer" > "$tmp"
  fi
  temp_text "Ollama Answer" "$tmp"
  rm -f "$tmp"
}

show_status() {
  local tmp
  tmp="$(mktemp)"
  "$script_dir/wiki-status-panel" > "$tmp"
  temp_text "Wiki Status" "$tmp"
  rm -f "$tmp"
}

open_trim_services() {
  xfce4-terminal --title="Trim Services" --hold --command="bash $repo_root/WIKI-TOOLS/handoff/04-trim-services.sh" >/dev/null 2>&1 &
}

open_lint() {
  xfce4-terminal --title="Wiki Lint" --hold --command="bash -lc 'cd "$repo_root" && PYTHONPATH="$repo_root" WIKI_OS_CONFIG="$HOME/.config/wiki-linux/config.json" python3 -m src.lint'" >/dev/null 2>&1 &
}

open_wiki_root() {
  xdg-open "$wiki_root" >/dev/null 2>&1 &
}

need_zenity

page_count="$(find "$wiki_root" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')"
daemon_status="$(systemctl --user is-active wiki-monitor 2>/dev/null || true)"
ollama_status="down"
if curl -fsS --max-time 3 http://127.0.0.1:11434/api/tags >/dev/null 2>&1; then
  ollama_status="active(api)"
elif systemctl --user is-active wiki-ollama.service 2>/dev/null | grep -q active; then
  ollama_status="active(user-service)"
elif systemctl is-active ollama 2>/dev/null | grep -q active; then
  ollama_status="active(system-service)"
fi

choice="$(zenity --list \
  --title="Wiki Dashboard" \
  --text="$page_count pages · wiki-monitor: ${daemon_status:-unknown} · ollama: ${ollama_status:-unknown}" \
  --width=720 --height=560 \
  --column="Action" --column="Description" \
  --print-column=1 \
  "Open Dashboard" "Open the landing note and next-session record" \
  "Ask Ollama" "Use the local wiki-aware model" \
  "Search Wiki" "Search markdown pages for a term" \
  "Open WebUI" "Open the local browser chat surface" \
  "Chromium AI" "Launch Chromium with the local AI page" \
  "Firefox AI" "Launch Firefox with the local AI page" \
  "Trim Services" "Disable non-essential and autoupdate-style services" \
  "Status" "Show a short health summary" \
  "New Note" "Create a new note in user/notes/" \
  "Lint Wiki" "Run the wiki link checker" \
  "Open Wiki Folder" "Open the vault folder in the file manager" \
  2>/dev/null)" || exit 0

case "$choice" in
  "Open Dashboard") open_dashboard ;;
  "Ask Ollama") ask_ollama ;;
  "Search Wiki") search_wiki ;;
  "Open WebUI") open_webui ;;
  "Chromium AI") open_chromium_ai ;;
  "Firefox AI") open_firefox_ai ;;
  "Trim Services") open_trim_services ;;
  "Status") show_status ;;
  "New Note") new_note ;;
  "Lint Wiki") open_lint ;;
  "Open Wiki Folder") open_wiki_root ;;
esac