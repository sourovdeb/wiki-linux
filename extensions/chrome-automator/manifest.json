{
  "manifest_version": 3,
  "name": "Wiki Automator",
  "version": "1.1.0",
  "description": "Batch email, LinkedIn/Medium posting, activity recording — powered by Playwright + Ollama SLM.",
  "permissions": [
    "storage",
    "cookies",
    "tabs",
    "activeTab",
    "scripting",
    "sidePanel",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://mail.proton.me/*",
    "https://www.linkedin.com/*",
    "https://medium.com/*",
    "http://127.0.0.1:7070/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://mail.proton.me/*",
        "https://www.linkedin.com/*",
        "https://medium.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "120"
}
