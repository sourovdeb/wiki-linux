{
  "_comment": "Wiki-Linux configuration. Copy to ~/.config/wiki-linux/config.json and edit.",

  "wiki": {
    "root": "~/wiki",
    "dirs": {
      "system":  "system",
      "user":    "user",
      "raw":     "raw",
      "meta":    "_meta",
      "tmp":     "_tmp",
      "archive": "_archive"
    }
  },

  "ollama": {
    "base_url":            "http://localhost:11434",
    "model":               "mistral",
    "context_limit_bytes": 8000,
    "temperature":         0.2,
    "num_ctx":             4096,
    "timeout_seconds":     30
  },

  "monitor": {
    "backend":          "inotify",
    "debounce_seconds": 5,
    "watch_dirs": [
      "~/wiki",
      "~/notes",
      "~/Downloads",
      "~/Documents"
    ],
    "log_file": "~/.cache/wiki-linux/monitor.log",
    "etc_allowlist": [
      "/etc/pacman.conf",
      "/etc/fstab",
      "/etc/hosts",
      "/etc/hostname",
      "/etc/locale.conf",
      "/etc/vconsole.conf",
      "/etc/ssh/sshd_config",
      "/etc/makepkg.conf",
      "/etc/mkinitcpio.conf",
      "/etc/systemd/system"
    ],
    "extensions": [
      ".md", ".txt", ".conf", ".service",
      ".timer", ".toml", ".yaml", ".ini",
      ".env", ".sh"
    ],
    "ignore_dirs": [
      ".git", "_tmp", ".obsidian", "__pycache__"
    ]
  },

  "git": {
    "auto_commit":             true,
    "commit_interval_minutes": 5,
    "remote":                  "",
    "branch":                  "main"
  },

  "search": {
    "max_snippets":        10,
    "snippet_context_lines": 2
  },

  "tools": {
    "tui_viewer": "mdt",
    "renderer":   "glow",
    "editor":     "nvim"
  },

  "fix": {
    "doc_roots": [
      "~/wiki",
      "~/.cache/wiki-linux/archwiki"
    ],
    "max_snippets":  8,
    "snippet_bytes": 2000
  },

  "obsidian": {
    "vault_path":    "~/wiki",
    "config_dir":    "~/.config/obsidian",
    "plugins": [
      "obsidian-git",
      "dataview",
      "templater-obsidian",
      "bmo-chatbot"
    ]
  },

  "openwebui": {
    "host":          "127.0.0.1",
    "port":          8080,
    "data_dir":      "~/.local/share/wiki-linux/openwebui-data",
    "venv":          "~/.local/share/wiki-linux/openwebui-venv",
    "knowledge_dir": "~/wiki",
    "auto_start":    false
  },

  "rescue": {
    "scan_dirs": [
      "~/Pictures",
      "~/Videos",
      "~/Music",
      "~/Public",
      "~/Templates",
      "~/Desktop"
    ],
    "extensions": [".md", ".txt", ".pdf", ".org", ".rst"],
    "ignore_dirs": [".cache", ".thumbnails", ".trash", "pytest-of-sourov", ".git", "node_modules", "__pycache__"]
  },

  "doctor": {
    "etc_snapshot": "~/.cache/wiki-linux/etc-snapshot.sha256"
  },

  "logging": {
    "level": "INFO",
    "file":  "~/wiki/_meta/daemon.log"
  }
}
