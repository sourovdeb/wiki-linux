#!/usr/bin/env bash
# wiki-welcome — shown at every login via autostart
# Displays a styled zenity dialog explaining how wiki-linux works.

WIKI_ROOT="${HOME}/wiki"
PROJECT_ROOT="${HOME}/Documents/wiki-linux/wiki-linux"

# Get live stats for the popup
page_count=$(find "$WIKI_ROOT" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
daemon_pid=$(systemctl --user show wiki-monitor.service --property=MainPID --value 2>/dev/null || echo 0)
[[ "${daemon_pid:-0}" -gt 0 ]] && daemon_status="● Running (PID $daemon_pid)" || daemon_status="○ Stopped"
timer_status=$(systemctl --user is-active wiki-sync.timer 2>/dev/null || echo inactive)
last_sync=$(git -C "$WIKI_ROOT" log -1 --format='%ci' 2>/dev/null || echo 'not synced yet')

zenity --info \
  --title="wiki-linux — your personal knowledge layer" \
  --width=560 \
  --height=420 \
  --ok-label="Open Terminal  (wiki help)" \
  --text="<b><big>  wiki-linux is running</big></b>

Your wiki has <b>${page_count} pages</b> at <tt>~/wiki/</tt>
Daemon: <b>${daemon_status}</b>   |   Sync timer: <b>${timer_status}</b>
Last sync: <tt>${last_sync}</tt>

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
<b>How this system works:</b>

 <b>1. Auto-documentation</b>
    The background daemon watches your files with inotify.
    Drop any file in a watched folder → the local LLM (Mistral)
    reads it and writes a wiki page automatically.
    Your <tt>/etc</tt> config files are mirrored as plain-English docs.

 <b>2. Three core operations  (open a terminal, run <tt>wiki</tt>)</b>

    <tt>wiki ingest ~/file.txt</tt>   — manually ingest any document
    <tt>wiki ask \"what does my fstab do?\"</tt>  — LLM Q&amp;A from wiki
    <tt>wiki lint</tt>                — find broken links / orphan pages

 <b>3. Your own notes</b>
    <tt>wiki new \"My note title\"</tt>  — creates a page and opens \$EDITOR
    <tt>wiki search \"GPU driver\"</tt>  — ripgrep search across all pages

 <b>4. Safety guarantees</b>
    • <tt>/etc</tt> is never written — read-only input only
    • Nothing is hard-deleted — files move to <tt>_archive/</tt>
    • Everything is in Git — run <tt>wiki sync</tt> to push to GitHub
    • All services run as your user — no root required

 <b>5. Full guide</b>
    <tt>cat ~/wiki/GUIDE.md</tt>   or   <tt>wiki open GUIDE</tt>

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
<i>This popup appears at every login. To disable it, remove
<tt>~/.config/autostart/wiki-welcome.desktop</tt></i>" 2>/dev/null

# If user clicked OK, open a terminal with wiki help ready
# (non-blocking — just exits if no terminal is found)
exit 0
