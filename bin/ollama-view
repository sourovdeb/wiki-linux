#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"
boot_check="$repo_root/WIKI-TOOLS/handoff/11-ai-boot-quick-check.sh"
url="http://127.0.0.1:8080"
browser="${1:-auto}"

start_user_service_if_present() {
  local unit="$1"
  if systemctl --user list-unit-files "$unit" >/dev/null 2>&1; then
    systemctl --user start "$unit" >/dev/null 2>&1 || true
  fi
}

wait_http() {
  local endpoint="$1"
  local retries="${2:-12}"
  local i
  for i in $(seq 1 "$retries"); do
    if curl -fsS --max-time 3 "$endpoint" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  return 1
}

if [[ -x "$boot_check" ]]; then
  "$boot_check" --quiet >/dev/null 2>&1 || true
fi

start_user_service_if_present "wiki-ollama.service"
start_user_service_if_present "wiki-openwebui.service"

open_url() {
  case "$browser" in
    chromium)
      if command -v chromium >/dev/null 2>&1; then
        chromium --new-window --enable-features=SidePanelPinning,ReadAnything "$url" >/dev/null 2>&1 &
        return 0
      fi
      ;;
    firefox)
      if command -v firefox >/dev/null 2>&1; then
        firefox --new-window "$url" >/dev/null 2>&1 &
        return 0
      fi
      ;;
    auto|*)
      if command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$url" >/dev/null 2>&1 &
        return 0
      fi
      ;;
  esac
  return 1
}

if wait_http "$url" 8; then
  open_url && exit 0
fi

# Retry once after explicit service start; do not launch separate desktop app profile.
start_user_service_if_present "wiki-openwebui.service"
if wait_http "$url" 12; then
  open_url && exit 0
fi

if command -v notify-send >/dev/null 2>&1; then
  notify-send "Ollama View" "Open WebUI app launched. Browser endpoint is still warming up."
fi
