#!/usr/bin/env bash
# Generate and display startup session report
set -euo pipefail

repo_root="${WIKI_ROOT:-/home/sourov/Documents/wiki-linux/wiki-linux}"
session_dir="$repo_root/_meta/session"
session_file="$session_dir/$(date +%Y%m%d-%H%M%S)-startup.md"

mkdir -p "$session_dir"

# Best-effort: previous startup report (for "since last session")
prev_session_file="$(ls -1t "$session_dir"/*-startup.md 2>/dev/null | head -n 1 || true)"

# Best-effort systemctl status (works even when systemd user bus isn't available)
systemctl_user_is_active() {
  local unit="$1"
  local out=""
  out="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
  out="${out%% *}"
  if [[ -z "$out" ]]; then
    echo "unknown"
    return 0
  fi
  echo "$out"
}

# Check system status
page_count=$(find "$repo_root" -name '*.md' 2>/dev/null | wc -l | tr -d ' ')
daemon_status="$(systemctl_user_is_active "wiki-monitor.service")"
ollama_status=$(curl -fsS --max-time 2 http://127.0.0.1:11434 >/dev/null 2>&1 && echo "yes" || echo "no")
webui_status=$(curl -fsS --max-time 2 http://127.0.0.1:8080 >/dev/null 2>&1 && echo "yes" || echo "no")
git_summary=$(git -C "$repo_root" log -1 --pretty='%ar — %s' 2>/dev/null || echo "no commits")

# Get recent changes
changed_files="  (no changes)"
if [[ -n "$prev_session_file" && -f "$prev_session_file" ]]; then
  changed_files="$(
    find "$repo_root" -type f \
      -not -path "$repo_root/.git/*" \
      -not -path "$repo_root/_meta/session/*" \
      -newer "$prev_session_file" 2>/dev/null \
      | sed "s#^$repo_root/##" \
      | head -n 8 \
      | sed 's/^/  • /' || true
  )"
  [[ -z "$changed_files" ]] && changed_files="  (no changes)"
else
  changed_files="$(
    git -C "$repo_root" diff --name-only HEAD~5..HEAD 2>/dev/null \
      | head -n 8 \
      | sed 's/^/  • /' || true
  )"
  [[ -z "$changed_files" ]] && changed_files="  (no changes)"
fi

# Detect issues
issues=""
[[ "$daemon_status" != "active" ]] && issues="${issues}- wiki-monitor is $daemon_status\n"
[[ "$ollama_status" != "yes" ]] && issues="${issues}- Ollama API is down\n"

# Generate report
cat > "$session_file" <<EOF
# Wiki-Linux Startup Report

**Session**: $(date '+%b %d, %Y %H:%M')  
**Status**: $([ -z "$issues" ] && echo "✓ All systems operational" || echo "⚠ Attention needed")

---

## System Status

| Component | Status |
|-----------|--------|
| Wiki pages | $page_count |
| wiki-monitor | $daemon_status |
| Ollama API | $ollama_status |
| Open WebUI | $webui_status |
| Latest commit | $git_summary |

---

## Since Last Session

Recent files changed:
$changed_files

---

## Quick Start

**Search**: \`Super+Space\` or \`wiki-search\`  
**Status**: \`wiki-status-panel\`  
**New note**: \`wiki new "title"\`  
**Ask AI**: Drop files in ~/Downloads, daemon auto-ingests

**Web UIs**:
- Ollama models: http://127.0.0.1:11434
- Open WebUI: http://127.0.0.1:8080

---

$([ -n "$issues" ] && echo "
## ⚠ Issues Detected

${issues}
Fix with: \`systemctl --user restart wiki-monitor\`
" || echo "")
EOF

# Display in terminal or GUI based on DISPLAY
if [[ -n "${DISPLAY:-}" ]] && command -v zenity >/dev/null 2>&1; then
  if ! zenity --text-info --title="Wiki-Linux Startup Report" --filename="$session_file" --width=700 --height=600 2>/dev/null; then
    cat "$session_file" || true
  fi
else
  cat "$session_file" || true
fi

printf "📊 Startup report: %s\n" "$session_file" 2>/dev/null || true
