{
  "commitMessage": "auto: vault sync {{date}} {{hostname}}",
  "commitDateFormat": "YYYY-MM-DD HH:mm:ss",
  "autoSaveInterval": 5,
  "autoPushInterval": 0,
  "autoPullInterval": 0,
